## 19. Routing escalable — lazy por feature

```typescript
// app.routes.ts — solo las rutas raíz, todo lazy
export const rutasApp: Routes = [
  {
    path: '',
    redirectTo: 'dashboard',
    pathMatch: 'full',
  },
  {
    path: 'dashboard',
    loadComponent: () => import('./features/dashboard/dashboard.component')
      .then(m => m.DashboardComponent),
  },
  {
    path: 'ordenes',
    canActivate: [guardAutenticacion],
    loadChildren: () => import('./features/ordenes/ordenes.routes')
      .then(m => m.rutasOrdenes),
  },
  {
    path: '**',
    loadComponent: () => import('./shared/ui/not-found/not-found.component')
      .then(m => m.NotFoundComponent),
  },
]

// features/ordenes/ordenes.routes.ts
export const rutasOrdenes: Routes = [
  {
    path: '',
    loadComponent: () => import('./ui/order-list/order-list.component')
      .then(m => m.OrderListComponent),
  },
  {
    path: ':id',
    loadComponent: () => import('./ui/order-detail/order-detail.component')
      .then(m => m.OrderDetailComponent),
    resolve: { orden: resolverOrden },
  },
]

// features/ordenes/order.resolver.ts
export const resolverOrden: ResolveFn<Order> = (ruta) => {
  const api       = inject(OrderApiService)
  const toast     = inject(ToastService)
  const enrutador = inject(Router)

  return api.obtenerPorId(ruta.paramMap.get('id')!).pipe(
    catchError(() => {
      toast.error('La orden no existe o no está disponible.')
      enrutador.navigate(['/ordenes'])
      return EMPTY
    })
  )
}
```

