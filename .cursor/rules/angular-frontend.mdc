## 15. Notificaciones al usuario — ToastService siempre

Todos los errores, éxitos y advertencias que el usuario necesita ver van por
el `ToastService`. Nunca mostrar errores técnicos al usuario.

```typescript
// toast.service.ts
@Injectable({ providedIn: 'root' })
export class ToastService {
  private toasts = signal<Toast[]>([])
  readonly todos  = this.toasts.asReadonly()

  exito(mensaje: string, duracion = 4000) {
    this.agregar({ tipo: 'exito', mensaje, icono: 'check_circle', duracion })
  }
  error(mensaje: string, duracion = 6000) {
    this.agregar({ tipo: 'error', mensaje, icono: 'error', duracion })
  }
  advertencia(mensaje: string, duracion = 5000) {
    this.agregar({ tipo: 'advertencia', mensaje, icono: 'warning', duracion })
  }
  info(mensaje: string, duracion = 4000) {
    this.agregar({ tipo: 'info', mensaje, icono: 'info', duracion })
  }

  private agregar(toast: Omit<Toast, 'id'>) {
    const id = crypto.randomUUID()
    this.toasts.update(t => [...t, { ...toast, id }])
  }

  descartar(id: string) {
    this.toasts.update(t => t.filter(x => x.id !== id))
  }
}
```

```html
<!-- toast-container.component.html — posición fija superior derecha -->
<div class="toast-container" role="region" aria-label="Notificaciones">
  @for (toast of toastService.todos(); track toast.id) {
    <div
      class="toast toast--{{ toast.tipo }}"
      role="alert"
      (mouseenter)="pausarTimer(toast.id)"
      (mouseleave)="reanudarTimer(toast.id)"
    >
      <span class="toast__icono material-icons">{{ toast.icono }}</span>
      <span class="toast__mensaje">{{ toast.mensaje }}</span>
      <button class="toast__cerrar" (click)="toastService.descartar(toast.id)"
              aria-label="Cerrar notificación">✕</button>
    </div>
  }
</div>
```

**Regla clave — mensajes amigables, no técnicos:**

```typescript
// MAL — mensaje técnico al usuario
toast.error('HttpErrorResponse: 500 Internal Server Error')
toast.error('Cannot read properties of undefined')

// BIEN — mensaje que el usuario entiende
toast.error('No se pudo guardar. Verificá tu conexión e intentá de nuevo.')
toast.exito('Cambios guardados correctamente.')
toast.advertencia('Tu sesión expira en 5 minutos.')
```

