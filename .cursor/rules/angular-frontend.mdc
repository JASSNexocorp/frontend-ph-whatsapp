## 14. NgRx Signal Store — estado global moderno

Usar NgRx Signal Store para estado compartido entre features. No usar NgRx clásico
(actions / reducers / effects) en código nuevo. No usar BehaviorSubject para estado global.

> **Advertencia DevTools:** El Signal Store no tiene soporte nativo para Redux DevTools.
> Para depurar estado, usar Angular DevTools. Si el proyecto necesita time-travel debugging,
> evaluar si el NgRx clásico sigue siendo necesario para ese store puntual.

```typescript
// order.store.ts
import { signalStore, withState, withMethods, withComputed } from '@ngrx/signals'
import { rxMethod } from '@ngrx/signals/rxjs-interop'
import { inject } from '@angular/core'

type EstadoOrdenes = {
  ordenes:  Order[]
  estado:   'inactivo' | 'cargando' | 'exito' | 'error'
  error:    string | null
}

const estadoInicial: EstadoOrdenes = {
  ordenes:  [],
  estado:   'inactivo',
  error:    null,
}

export const OrderStore = signalStore(
  { providedIn: 'root' },
  withState(estadoInicial),

  withComputed(({ ordenes }) => ({
    totalOrdenes:      computed(() => ordenes().length),
    tieneOrdenes:      computed(() => ordenes().length > 0),
    ordenesPendientes: computed(() => ordenes().filter(o => o.status === 'pending')),
  })),

  withMethods((store, api = inject(OrderApiService), toast = inject(ToastService)) => ({

    async cargarOrdenes() {
      // FASE 1: Marcamos como cargando antes del request
      patchState(store, { estado: 'cargando', error: null })
      try {
        // FASE 2: Llamamos a la API y guardamos el resultado
        const ordenes = await firstValueFrom(api.obtenerTodas())
        patchState(store, { ordenes, estado: 'exito' })
      } catch {
        // FASE 3: Error — mensaje amigable al usuario, nunca técnico
        const mensajeError = 'No se pudieron cargar las órdenes. Intentá de nuevo.'
        patchState(store, { estado: 'error', error: mensajeError })
        toast.error(mensajeError)
      }
    },

    async crearOrden(nuevaOrden: CreateOrderDto) {
      try {
        const creada = await firstValueFrom(api.crear(nuevaOrden))
        patchState(store, { ordenes: [...store.ordenes(), creada] })
        toast.success('Orden creada correctamente.')
      } catch {
        toast.error('No se pudo crear la orden. Intentá de nuevo.')
      }
    },

    buscarOrdenes: rxMethod<string>(
      pipe(
        debounceTime(300),
        distinctUntilChanged(),
        switchMap(termino =>
          api.buscar(termino).pipe(
            tapResponse({
              next: ordenes => patchState(store, { ordenes, estado: 'exito' }),
              error: () => toast.error('No se pudo realizar la búsqueda.')
            })
          )
        )
      )
    ),
  }))
)
```

Consumo en el componente:

```typescript
@Component({ standalone: true, changeDetection: ChangeDetectionStrategy.OnPush })
export class OrderListComponent {
  private store = inject(OrderStore)

  ordenes      = this.store.ordenes
  tieneOrdenes = this.store.tieneOrdenes
  estado       = this.store.estado

  ngOnInit() { this.store.cargarOrdenes() }
}
```

