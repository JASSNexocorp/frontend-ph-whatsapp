## 12. Estados completos en componentes

Todo componente que consume datos asíncronos maneja los 4 estados.

```typescript
estado  = signal<'inactivo' | 'cargando' | 'exito' | 'error'>('inactivo')
ordenes = signal<Order[]>([])
error   = signal<string | null>(null)
```

```html
@switch (estado()) {
  @case ('cargando') { <app-skeleton /> }
  @case ('error')    { <app-error-state [mensaje]="error()" /> }
  @case ('exito') {
    @if (ordenes().length === 0) {
      <app-empty-state />
    } @else {
      @for (orden of ordenes(); track orden.id) {
        <app-order-card [orden]="orden" />
      }
    }
  }
}
```

