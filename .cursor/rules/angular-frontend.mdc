## 17. Validación de formularios — validators custom tipados

```typescript
// validators/password.validator.ts
export function validadorPasswordFuerte(): ValidatorFn {
  return (control: AbstractControl): ValidationErrors | null => {
    const val = control.value as string
    if (!val) return null
    const tieneMayuscula  = /[A-Z]/.test(val)
    const tieneNumero     = /\d/.test(val)
    const tieneEspecial   = /[!@#$%^&*]/.test(val)
    return tieneMayuscula && tieneNumero && tieneEspecial
      ? null
      : { passwordFuerte: { tieneMayuscula, tieneNumero, tieneEspecial } }
  }
}

// validators/match-fields.validator.ts
export function validadorCamposCoinciden(campo1: string, campo2: string): ValidatorFn {
  return (grupo: AbstractControl): ValidationErrors | null => {
    const a = grupo.get(campo1)?.value
    const b = grupo.get(campo2)?.value
    return a === b ? null : { camposNoCoinciden: true }
  }
}

// validators/email-taken.validator.ts
export function validadorEmailOcupado(apiUsuarios: UserApiService): AsyncValidatorFn {
  return (control: AbstractControl) =>
    control.valueChanges.pipe(
      debounceTime(400),
      distinctUntilChanged(),
      switchMap(email => apiUsuarios.verificarEmailDisponible(email)),
      map(disponible => disponible ? null : { emailOcupado: true }),
      first()
    )
}
```

```typescript
formulario = new FormGroup({
  email: new FormControl('', {
    nonNullable: true,
    validators:      [Validators.required, Validators.email],
    asyncValidators: [validadorEmailOcupado(inject(UserApiService))],
    updateOn:        'blur',
  }),
  password: new FormControl('', {
    nonNullable: true,
    validators: [Validators.required, Validators.minLength(8), validadorPasswordFuerte()],
  }),
  confirmarPassword: new FormControl('', { nonNullable: true }),
}, {
  validators: validadorCamposCoinciden('password', 'confirmarPassword'),
})

erroresEmail = computed(() => {
  const ctrl = this.formulario.controls.email
  if (!ctrl.dirty) return null
  if (ctrl.hasError('required'))    return 'El email es requerido'
  if (ctrl.hasError('email'))       return 'El formato no es válido'
  if (ctrl.hasError('emailOcupado')) return 'Este email ya está en uso'
  return null
})
```

```html
<input [formControl]="formulario.controls.email" type="email" />
@if (erroresEmail()) {
  <span class="campo-error" role="alert">{{ erroresEmail() }}</span>
}
```

