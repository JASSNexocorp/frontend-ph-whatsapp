## Anti-patrones — lo que NO se debe hacer

### Estado
```typescript
// NO — mutar signals directamente
this.ordenes().push(nuevaOrden)

// SÍ — crear nueva referencia
this.ordenes.update(prev => [...prev, nuevaOrden])
```

```typescript
// NO — BehaviorSubject para estado simple de componente
private _estaAbierto$ = new BehaviorSubject(false)

// SÍ — signal
estaAbierto = signal(false)
```

### Componentes
```typescript
// NO — lógica de negocio en el componente
@Component(...)
export class OrderListComponent {
  calcularTotal(ordenes: Order[]) {
    return ordenes.reduce((acc, o) => acc + o.precio * o.cantidad, 0)
  }
}

// SÍ — la lógica va en el dominio o en un caso de uso
export function calcularTotalOrdenes(ordenes: Order[]): number {
  return ordenes.reduce((acc, o) => acc + o.precio * o.cantidad, 0)
}
```

```typescript
// NO — prop drilling profundo via input()
// AbueloComponent → PadreComponent → HijoComponent → NietoComponent

// SÍ — inject() del store en el nivel correcto
export class NietoComponent {
  private store = inject(OrderStore)
}
```

### CSS
```css
/* NO — estilos globales para lógica de componente */
.order-card { ... }

/* SÍ — en order-card.component.css */
:host { ... }
:host(.seleccionado) { ... }
```

### Templates
```html
<!-- NO — lógica compleja en el template -->
<div *ngIf="usuario && usuario.ordenes && usuario.ordenes.length > 0 && !cargando">

<!-- SÍ — computed signal con nombre semántico -->
@if (tieneOrdenes()) { ... }
```

```html
<!-- NO — @for sin track -->
@for (orden of ordenes()) { ... }

<!-- SÍ — track siempre por id único -->
@for (orden of ordenes(); track orden.id) { ... }
```

### Performance
```typescript
// NO — subscribe sin cleanup en componentes
ngOnInit() {
  this.service.datos$.subscribe(d => this.datos = d)
}

// SÍ — toSignal() gestiona el cleanup automáticamente
datos = toSignal(this.service.datos$, { initialValue: [] })

// O con takeUntilDestroyed
private refDestruccion = inject(DestroyRef)
ngOnInit() {
  this.service.datos$
    .pipe(takeUntilDestroyed(this.refDestruccion))
    .subscribe(d => this.datos.set(d))
}
```

