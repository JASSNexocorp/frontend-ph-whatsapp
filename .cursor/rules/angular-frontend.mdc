## 16. HTTP Interceptors — centralizados y funcionales

```typescript
// auth.interceptor.ts — agrega el token a cada request
export const interceptorAutenticacion: HttpInterceptorFn = (req, next) => {
  const auth  = inject(AuthService)
  const token = auth.token()

  if (!token) return next(req)

  return next(req.clone({
    setHeaders: { Authorization: `Bearer ${token}` }
  }))
}

// error.interceptor.ts — maneja errores HTTP globalmente
export const interceptorError: HttpInterceptorFn = (req, next) => {
  const toast      = inject(ToastService)
  const enrutador  = inject(Router)
  const auth       = inject(AuthService)

  return next(req).pipe(
    catchError((err: HttpErrorResponse) => {
      switch (err.status) {
        case 401:
          auth.cerrarSesion()
          enrutador.navigate(['/login'])
          toast.advertencia('Tu sesión expiró. Iniciá sesión de nuevo.')
          break
        case 403:
          toast.error('No tenés permiso para realizar esta acción.')
          break
        case 0:
          toast.error('Sin conexión. Verificá tu red e intentá de nuevo.')
          break
        default:
          toast.error('Algo salió mal. Intentá de nuevo en unos minutos.')
      }
      return throwError(() => err)
    })
  )
}

// loading.interceptor.ts — muestra loading global opcional
export const interceptorCarga: HttpInterceptorFn = (req, next) => {
  const cargando = inject(LoadingService)
  cargando.iniciar()
  return next(req).pipe(finalize(() => cargando.detener()))
}
```

```typescript
// app.config.ts — registro de interceptors
export const appConfig: ApplicationConfig = {
  providers: [
    provideHttpClient(
      withInterceptors([interceptorAutenticacion, interceptorError, interceptorCarga])
    ),
  ]
}
```

